# ─── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── URL pública do app ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://devfactory.vercel.app

# ─── Router (classificação de complexidade) ─────────────────────────────────
# Usa SEMPRE modelos gratuitos — é infraestrutura interna da plataforma,
# nunca executa código do usuário.
ROUTER_PROVIDER=google
ROUTER_MODEL=gemini-flash-lite-latest

# ─── Keys DE PLATAFORMA — modelos Tier 1 gratuitos ─────────────────────────
#
# IMPORTANTE — leia antes de preencher:
#
# Estas keys são SUAS e ficam no Vercel. Cobrem APENAS modelos com free tier
# real (custo zero ou negligível para uso pessoal/LTDA).
#
# Modelos PAGOS (Claude Opus, GPT-5.5, DeepSeek Pro, Qwen Max, etc.) NUNCA
# usam estas keys. Cada usuário configura a própria key em /settings/api-keys
# dentro do app (modelo BYOK). Você NÃO paga pelos modelos pagos dos usuários.
#
# Para uso pessoal/LTDA: custo efetivamente zero.
# Para produto público com muitos usuários: monitorar consumo dos free tiers.

# Google AI Studio — 1.500 req/dia gratuitos (Gemini Flash-Lite para o Router)
# Obter em: https://aistudio.google.com/apikey
PLATFORM_GOOGLE_FREE_TIER_KEY=

# DeepSeek — free tier disponível (DeepSeek V4 Flash, Tier 1)
# Obter em: https://platform.deepseek.com/api_keys
PLATFORM_DEEPSEEK_FREE_TIER_KEY=

# GLM/Z.AI — GLM-4.7-Flash é permanentemente gratuito
# Obter em: https://open.bigmodel.cn/usercenter/apikeys
PLATFORM_GLM_FREE_TIER_KEY=

# Qwen/Alibaba — Qwen Flash com free tier
# Obter em: https://dashscope.console.aliyun.com/apiKey
PLATFORM_QWEN_FREE_TIER_KEY=

# Groq — free tier generoso para Llama
# Obter em: https://console.groq.com/keys
PLATFORM_GROQ_FREE_TIER_KEY=

# ─── GitHub OAuth (modo brownfield — opcional no início) ────────────────────
# Necessário apenas para conectar repositórios GitHub existentes.
# Criar em: github.com/settings/developers → New OAuth App
#   Homepage URL:  https://devfactory.vercel.app
#   Callback URL:  https://devfactory.vercel.app/api/github/connect/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ─── Criptografia das API keys BYOK dos usuários ───────────────────────────
# Criptografa as keys que cada usuário configura em /settings/api-keys.
# Gerar: openssl rand -base64 32
# NUNCA versionar — só no Vercel e localmente via .env.local
BYOK_ENCRYPTION_KEY=
